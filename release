#!/bin/bash
set -euo pipefail

# Usage: ./release patch|minor|major
#
# Bumps version, creates a GitHub release with tag, which triggers npm publish.

BUMP="${1:?Usage: ./release patch|minor|major}"

if [[ "$BUMP" != "patch" && "$BUMP" != "minor" && "$BUMP" != "major" ]]; then
  echo "Usage: ./release patch|minor|major" >&2
  exit 1
fi

# Ensure clean working directory
if [[ -n "$(git status --porcelain)" ]]; then
  echo "Working directory not clean. Commit or stash changes first." >&2
  exit 1
fi

# Get current version and calculate next
CURRENT=$(node -p "require('./package.json').version")
NEXT=$(npx semver "$CURRENT" -i "$BUMP" 2>/dev/null || node -e "
  const [maj,min,pat] = '$CURRENT'.split('.').map(Number);
  if ('$BUMP'==='patch') console.log(maj+'.'+min+'.'+(pat+1));
  if ('$BUMP'==='minor') console.log(maj+'.'+(min+1)+'.0');
  if ('$BUMP'==='major') console.log((maj+1)+'.0.0');
")

echo "Releasing v$NEXT (was $CURRENT)"

# Create GitHub release (triggers the publish workflow)
gh release create "v$NEXT" --title "v$NEXT" --generate-notes

echo ""
echo "Release v$NEXT created. GitHub Action will publish to npm."
