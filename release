#!/bin/bash
set -euo pipefail

# Usage: ./release patch|minor|major
#
# Creates a release branch with version bump, opens a PR.
# After merge, tag and push to trigger npm publish.

BUMP="${1:?Usage: ./release patch|minor|major}"

if [[ "$BUMP" != "patch" && "$BUMP" != "minor" && "$BUMP" != "major" ]]; then
  echo "Usage: ./release patch|minor|major" >&2
  exit 1
fi

if [[ -n "$(git status --porcelain)" ]]; then
  echo "Working directory not clean. Commit or stash changes first." >&2
  exit 1
fi

# Make sure we're on latest main
git checkout main
git pull

# Calculate next version
CURRENT=$(node -p "require('./package.json').version")
NEXT=$(node -e "
  const [maj,min,pat] = '$CURRENT'.split('.').map(Number);
  if ('$BUMP'==='patch') console.log(maj+'.'+min+'.'+(pat+1));
  if ('$BUMP'==='minor') console.log(maj+'.'+(min+1)+'.0');
  if ('$BUMP'==='major') console.log((maj+1)+'.0.0');
")

BRANCH="release/v$NEXT"

# Create release branch
git checkout -b "$BRANCH"

# Bump version in package.json (no git tag)
npm version "$NEXT" --no-git-tag-version
git add package.json
git commit -m "Release v$NEXT"

# Push and create PR
git push -u origin "$BRANCH"
gh pr create --title "Release v$NEXT" --body "Bump version to v$NEXT.

On merge, the tag-release workflow auto-tags \`v$NEXT\` which triggers npm publish."

echo ""
echo "PR created. Merge it — tagging and npm publish happen automatically."
