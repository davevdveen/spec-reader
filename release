#!/bin/bash
set -euo pipefail

# Usage: ./release patch|minor|major
#
# Bumps version in package.json, commits, tags, pushes.
# The GitHub Action publishes to npm when it sees the tag.

BUMP="${1:?Usage: ./release patch|minor|major}"

if [[ "$BUMP" != "patch" && "$BUMP" != "minor" && "$BUMP" != "major" ]]; then
  echo "Usage: ./release patch|minor|major" >&2
  exit 1
fi

if [[ -n "$(git status --porcelain)" ]]; then
  echo "Working directory not clean. Commit or stash changes first." >&2
  exit 1
fi

# Bump version, commit, and tag (npm does all three)
npm version "$BUMP" -m "Release %s"

# Push the commit and tag
git push && git push --tags

echo ""
echo "GitHub Action will publish to npm."
